# Maintainer: sickhate <archate@gmail.com>
pkgname=meh-default-config
pkgver=0.1.0.r15.318e895
pkgrel=1
pkgdesc="GTK4 Wayland-only widget system and status bar — embedded minimal bar, no config needed"
arch=('x86_64')
url="https://github.com/sickhate/meh"
license=('GPL-3.0-or-later')
depends=(
    'gtk4'
    'gtk4-layer-shell'
    'libadwaita'
    'cairo'
    'glib2'
    'pango'
)
makedepends=('rust' 'cargo')
options=('!debug')
source=("meh::git+file://${HOME}/Projects/meh")
sha256sums=('SKIP')

prepare() {
    cd "$srcdir/meh"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$srcdir/meh"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --locked --features default,builtin-default-config
}

check() {
    cd "$srcdir/meh"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --release --locked 2>/dev/null || true
}

package() {
    cd "$srcdir/meh"
    install -Dm755 "target/release/meh" "$pkgdir/usr/bin/meh"
    install -Dm644 "Cargo.toml" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

pkgver() {
    cd "$srcdir/meh"
    printf "0.1.0.r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}
